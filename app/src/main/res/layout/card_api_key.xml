<?xml version="1.0" encoding="utf-8"?>
<!--
  بطاقة قابلة لإعادة الاستخدام لإدخال مفتاح API لمحرك واحد.
  تُضمَّن 4 مرات في شاشة الإعدادات (Claude/Gemini/Groq/HF).
  الحقول المتاحة عبر ViewBinding:
    - textEngineName: عنوان البطاقة (اسم المحرك)
    - textEngineDesc: وصف مختصر
    - editApiKey: حقل إدخال المفتاح (masked)
    - buttonClearKey: زر حذف المفتاح
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textEngineName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/textEngineDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/editApiKey"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="textPassword"
                android:hint="@string/settings_key_hint"
                android:textSize="13sp"
                android:maxLines="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonClearKey"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_clear_key"
                android:textColor="@color/accent" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
