<?xml version="1.0" encoding="utf-8"?>
<!--
  شاشة Dashboard (Modern Minimalist) — ملخص مالي مرئي شامل
  المكوّنات:
   1. بطاقة الإجمالي الكبير (Hero Stat)
   2. شبكة بطاقات الإحصائيات (4 بطاقات: عدد، متوسط، أعلى، مراجعة)
   3. مخطط دائري لتوزيع البنوك (بالنسب المئوية)
   4. مخطط عمودي للإجمالي الشهري
   5. قائمة أكثر الجهات
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/analyticsToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:titleTextColor="@color/text_primary"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- ===== 1) بطاقة الإجمالي الكبير ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/card_background"
                android:padding="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_total_label"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/textTotalAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/text_primary"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.03" />

                <TextView
                    android:id="@+id/textTotalCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- ===== 2) شبكة الإحصائيات (2×2) ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/card_background"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_avg"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/textStatAvg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/card_background"
                    android:padding="16dp"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_max"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/textStatMax"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/card_background"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_banks"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/textStatBanks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/accent_dark"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/card_background"
                    android:padding="16dp"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_review"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/textStatReview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/confidence_low"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- ===== حالة فارغة ===== -->
            <TextView
                android:id="@+id/textNoData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:gravity="center"
                android:padding="24dp"
                android:text="@string/analytics_no_data"
                android:textColor="@color/text_hint"
                android:visibility="gone" />

            <!-- ===== 3) عنوان قسم المخطط الدائري ===== -->
            <TextView
                android:id="@+id/textBankDistTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/dashboard_bank_distribution"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/textBankDistSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/dashboard_bank_distribution_desc"
                android:textSize="11sp"
                android:textColor="@color/text_hint" />

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChart"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_marginTop="16dp" />

            <!-- قائمة البنوك بالنسب -->
            <LinearLayout
                android:id="@+id/bankListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical" />

            <!-- ===== 4) عنوان قسم المخطط العمودي ===== -->
            <TextView
                android:id="@+id/textMonthlyTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/analytics_monthly_title"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/dashboard_monthly_desc"
                android:textSize="11sp"
                android:textColor="@color/text_hint" />

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/barChart"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginTop="16dp" />

            <!-- ===== 5) قسم أكثر الجهات ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/analytics_top_title"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="@color/text_primary" />

            <LinearLayout
                android:id="@+id/topContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
