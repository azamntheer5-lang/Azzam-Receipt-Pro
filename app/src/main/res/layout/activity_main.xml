<?xml version="1.0" encoding="utf-8"?>
<!--
  الشاشة الرئيسية (إعادة تصميم جذري - فلسفة "Financial Elegance")
  المكونات:
   1. شريط أدوات شفاف بدون خلفية ملونة (يندمج مع الهيرو)
   2. بطاقة هيرو (Hero) بتدرّج زمردي: الإجمالي بحجم ضخم + ذهبي للتنبيه
   3. شريط بحث حديث بزاوية 28dp
   4. قائمة RecyclerView
   5. Bottom Navigation (رئيسية/كشف/تحليلات/إعدادات)
   6. FAB دائري مميز
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ===== حاوية الإذن (تظهر قبل منح صلاحية الملفات) ===== -->
    <LinearLayout
        android:id="@+id/permissionContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_receipt_modern"
            android:background="@drawable/bg_icon_circle"
            android:padding="20dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/permission_required_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/permission_required_desc"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonGrantPermission"
            style="@style/Widget.GoldButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:text="@string/grant_permission" />
    </LinearLayout>

    <!-- ===== الحاوية الرئيسية ===== -->
    <LinearLayout
        android:id="@+id/mainContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- شريط الأدوات: شفاف ليتمازج مع الهيرو -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:titleTextColor="@color/text_primary"
            app:menu="@menu/main_menu" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollContent"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ===== بطاقة الهيرو: الإجمالي بتدرّج زمردي ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical"
                    android:background="@drawable/gradient_hero"
                    android:padding="28dp"
                    android:elevation="8dp">

                    <!-- صف علوي: عنوان + أيقونة -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/hero_total_label"
                                android:textColor="#B0FFFFFF"
                                android:textSize="13sp"
                                android:letterSpacing="0.05" />

                            <TextView
                                android:id="@+id/textTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="#FFFFFF"
                                android:textSize="36sp"
                                android:textStyle="bold"
                                android:letterSpacing="-0.02"
                                tools:text="١٬٢٣٤٫٥٦ ر.س" />
                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_icon_circle">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_receipt_modern" />
                        </FrameLayout>
                    </LinearLayout>

                    <!-- فاصل ناعم -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="16dp"
                        android:background="#33FFFFFF" />

                    <!-- صف سفلي: العدد + تنبيه المراجعة -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/textCount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="#E0FFFFFF"
                            android:textSize="13sp"
                            tools:text="٤٢ إيصال" />

                        <TextView
                            android:id="@+id/textNeedsReview"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFCDD2"
                            android:textSize="12sp"
                            android:drawableStart="@drawable/ic_review_warning"
                            android:drawablePadding="6dp"
                            android:gravity="center_vertical"
                            android:visibility="gone"
                            tools:text="٣ يحتاج مراجعة" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== شريط البحث الحديث ===== -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="16dp">

                    <EditText
                        android:id="@+id/editSearch"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingStart="52dp"
                        android:paddingEnd="20dp"
                        android:background="@drawable/bg_search_rounded"
                        android:hint="@string/search_hint"
                        android:inputType="text"
                        android:imeOptions="actionSearch"
                        android:maxLines="1"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="14sp"
                        android:elevation="2dp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="start|center_vertical"
                        android:layout_marginStart="16dp"
                        android:src="@drawable/ic_search_modern"
                        app:tint="@color/text_hint" />
                </FrameLayout>

                <!-- ===== عنوان القائمة ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="4dp"
                    android:text="@string/recent_transfers_title"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary" />

                <!-- ===== حالة فارغة ===== -->
                <LinearLayout
                    android:id="@+id/textEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="60dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_receipt_modern"
                        app:tint="@color/text_hint"
                        android:alpha="0.4" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/empty_list"
                        android:textColor="@color/text_hint"
                        android:textSize="14sp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- ===== القائمة ===== -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:clipToPadding="false"
                    android:paddingBottom="100dp"
                    tools:listitem="@layout/item_transfer" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <!-- ===== زر المسح العائم ===== -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabScanNow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:layout_marginBottom="80dp"
        android:contentDescription="@string/scan_now"
        android:src="@drawable/ic_receipt_modern"
        app:backgroundTint="@color/primary"
        app:tint="@color/text_on_primary"
        app:elevation="6dp"
        app:fabSize="normal" />

    <!-- ===== شريط التنقل السفلي ===== -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/card_background"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@color/primary"
        app:itemTextColor="@color/primary"
        app:elevation="8dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
