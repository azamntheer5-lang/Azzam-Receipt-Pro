<?xml version="1.0" encoding="utf-8"?>
<!--
  نافذة تعديل السجل (مُعاد تصميمها في المرحلة 2).
  حل مشكلة "الحقول الفارغة":
   - تسميات (labels) واضحة لكل حقل بدل hint فقط
   - عرض النص الخام المستخرَج (rawText) واسم الملف المصدر للمساعدة في التعبئة اليدوية
   - عرض المحرك المستخدم (llmEngineUsed) للتشخيص
   - حقل التاريخ قابل للنقر لفتح Date Picker
   - حقل المبلغ ببادئة عملة واضحة
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- شريط سياق: المصدر + المحرك -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F0F0F0"
        android:padding="10dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/textContextSource"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/textContextEngine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@color/accent"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <!-- المرسل -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/field_sender">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editSender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- المستلم -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:hint="@string/field_recipient">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editRecipient"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- المبلغ -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:hint="@string/field_amount"
        app:prefixText="SAR ">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- التاريخ (قابل للنقر لفتح Date Picker) -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:hint="@string/field_date"
        app:endIconDrawable="@android:drawable/ic_menu_today"
        app:endIconMode="custom">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:focusable="false"
            android:cursorVisible="false" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- قسم: النص الخام المستخرَج (مراجعة) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/edit_raw_text_section"
        android:textStyle="bold"
        android:textSize="13sp"
        android:textColor="@color/text_primary" />

    <TextView
        android:id="@+id/textRawOcr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="#F8F8F8"
        android:padding="10dp"
        android:textSize="11sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="monospace"
        android:maxLines="6"
        android:ellipsize="end"
        android:scrollbars="vertical"
        android:textIsSelectable="true" />

</LinearLayout>
